# Home Assistant Configuration Management Environment Variables
# Copy this file to .env in your project root and fill in your actual values

# Home Assistant Configuration
HA_TOKEN=your_home_assistant_long_lived_access_token_here
HA_URL=http://your_homeassistant_host:8123

# SSH Configuration for rsync operations
# This should match your SSH config for connecting to Home Assistant
HA_HOST=your_homeassistant_host
HA_REMOTE_PATH=/config/

# Local Configuration (optional - defaults provided)
LOCAL_CONFIG_PATH=config/
BACKUP_DIR=backups
TOOLS_PATH=tools

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Edit .env with your actual Home Assistant details
# 3. Set up SSH access to your Home Assistant instance (see ~/.ssh/config)
# 4. Run: pixi run pull (or make pull) to sync your configuration
